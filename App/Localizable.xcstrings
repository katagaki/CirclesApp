        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "тЈїтЄ╗ТЉіСйЇС╗ЦтѕЄТЇбтЈѓУДѓуіХТђЂсђѓ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "жЏЎТЊіТћцСйЇС╗ЦтѕЄТЈЏтЈЃУДђуІђТЁІсђѓ"
