    "Notifier.Explainer": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set notifications before the event starts, when the event starts, and when the event ends. Settings may vary depending on the ticket you selected."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "сѓцсЃЎсЃ│сЃѕжќІтѓгтЅЇсђЂжќІтѓгТЎѓсђЂжќЅС╝џТЎѓсЂ«жђџуЪЦсЂїУеГт«џсЂДсЂЇсЂЙсЂЎсђѓУеГт«џсЂДсЂЇсѓІжђџуЪЦсЂ»сђЂсЃЂсѓ▒сЃЃсЃѕ№╝ѕтЈѓтіаТЎѓжќЊ№╝ЅсЂФсѓѕсЂБсЂдуЋ░сЂфсѓісЂЙсЂЎсђѓ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ВЮ┤в▓цьіИ ВІюВъЉ Ваё, ВІюВъЉ ВІю, ВбЁвБї ВІю ВЋївд╝ВЮё ВёцВаЋьЋЕвІѕвІц. ВёцВаЋВЮђ ВёаьЃЮьЋю ьІ░В╝ЊВЌљ вћ░вЮ╝ вІгвЮ╝ВДѕ Вѕў ВъѕВіхвІѕвІц."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "У«Йт«џТ┤╗тіет╝ђтДІтЅЇсђЂт╝ђтДІТЌХтњїу╗ЊТЮЪТЌХуџёжђџуЪЦсђѓУ«Йт«џтЈ»УЃйС╝џСЙЮТѓежђЅТІЕуџёуЦетѕИУђїТюЅТЅђСИЇтљїсђѓ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "УеГт«џТ┤╗тІЋжќІтДІтЅЇсђЂжќІтДІТЎѓтњїухљТЮЪТЎѓуџёжђџуЪЦсђѓУеГт«џтЈ»УЃйТюЃСЙЮТѓежЂИТЊЄуџёуЦетѕИУђїТюЅТЅђСИЇтљїсђѓ"
          }
        }
      }
    },
