    "More.Disclaimer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Comic Market, Circle.ms, and Tokyo Big Sight bear no responsibility for any issues that may arise with this app. For inquiries, please use the below support options."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ТюгсѓбсЃЌсЃфсЂ«СИЇтЁитљѕсЂФсЂцсЂёсЂдсђЂсѓ│сЃЪсѓ▒сЃЃсЃѕсђЂCircle.msсђЂТЮ▒С║гсЃЊсЃЃсѓ░сѓхсѓцсЃѕсЂ»У▓гС╗╗сѓњСИђтѕЄУ▓асЂёсЂЙсЂЏсѓЊсђѓсЂітЋЈсЂётљѕсѓЈсЂЏсЂ»сђЂС╗ЦСИІсЂ«жђБухАтЁѕсЂЙсЂДсЂіжАўсЂёсЂёсЂЪсЂЌсЂЙсЂЎсђѓ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Comic Market, Circle.ms в░Ј Tokyo Big Sightвіћ ВЮ┤ ВЋ▒ВЌљВёю в░юВЃЮьЋа Вѕў Въѕвіћ вгИВаюВЌљ вїђьЋ┤ В▒ЁВъёВЮё ВДђВДђ ВЋіВіхвІѕвІц. вгИВЮў ВѓгьЋГВЮђ ВЋёвъў ВДђВЏљ ВўхВЁўВЮё ВЮ┤ВџЕьЋ┤ ВБ╝ВёИВџћ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Comic MarketсђЂCircle.msтњїСИюС║гBig Sightт»╣С║јТюгт║ћућеуеІт║ЈтЈ»УЃйС║ДућЪуџёС╗╗СйЋжЌ«жбўТдѓСИЇУ┤ЪУ┤БсђѓтдѓТюЅуќЉжЌ«№╝їУ»иСй┐ућеС╗ЦСИІТћ»ТїЂжђЅжА╣сђѓ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Comic MarketсђЂCircle.msтњїТЮ▒С║гBig Sightт░ЇТќ╝ТюгТЄЅућеуеІт╝ЈтЈ»УЃйућбућЪуџёС╗╗СйЋтЋЈжАїТдѓСИЇУ▓аУ▓гсђѓтдѓТюЅуќЉтЋЈ№╝їУФІСй┐ућеС╗ЦСИІТћ»ТЈ┤жЂИжаЁсђѓ"
