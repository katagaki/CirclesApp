    "Tip.DoubleTapVisit.Description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Double tap on a circle to toggle its visit status."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "сѓхсЃ╝сѓ»сЃФсѓњсЃђсЃќсЃФсѓ┐сЃЃсЃЌсЂЌсЂдсђЂУефтЋЈуіХТ│ЂсѓњсЃъсЃ╝сѓ»сЂЌсЂЪсѓіУДБжЎцсЂЌсЂЪсѓісЂДсЂЇсЂЙсЂЎсђѓ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ВёюьЂ┤ВЮё вЉљ в▓ѕ ьЃГьЋўВЌг в░ЕвгИ ВЃЂьЃювЦ╝ ВаёьЎўьЋўВёИВџћ."
