        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "сѓхсЃ╝сѓ»сЃФсЂ«жќЅС╝џТЎѓжќЊсЂДсЂЎсђѓсЂЙсЂЪТгАтЏъсЂіС╝џсЂёсЂЌсЂЙсЂЌсѓЄсЂє№╝Ђ"
